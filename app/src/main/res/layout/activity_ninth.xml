<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home.pertemuan_9.NinthActivity">

  <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="0dp"
      android:layout_height="?attr/actionBarSize"
      android:background="#D700FF"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:title=""
      app:titleCentered="true"
      app:titleTextColor="@android:color/white" />

  <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/textInputLayout"
      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginHorizontal="35dp"
      android:layout_marginTop="24dp"
      android:hint="Email"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintHorizontal_bias="1.0"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/toolbar"
      app:startIconDrawable="@drawable/ic_edit">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textEmailAddress" />
  </com.google.android.material.textfield.TextInputLayout>

  <com.google.android.material.button.MaterialButton
      android:id="@+id/btnLogin"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginHorizontal="35dp"
      android:layout_marginTop="10dp"
      android:text="Login"
      app:icon="@drawable/ic_login"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/textInputLayout" />

  <com.google.android.material.chip.ChipGroup
      android:id="@+id/chipGroupFilter"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="25dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/btnLogin"
      app:singleSelection="false">

    <com.google.android.material.chip.Chip
        android:id="@+id/chipTerbaru"
        style="@style/Widget.MaterialComponents.Chip.Filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="Terbaru" />

    <com.google.android.material.chip.Chip
        android:id="@+id/chipPenting"
        style="@style/Widget.MaterialComponents.Chip.Filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Penting" />

    <com.google.android.material.chip.Chip
        android:id="@+id/chipBelumDibaca"
        style="@style/Widget.MaterialComponents.Chip.Filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Belum Dibaca" />

  </com.google.android.material.chip.ChipGroup>

    <EditText
        android:id="@+id/etCustom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="120dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/edit_text_background"
        android:hint="Custom Background EditText"
        android:inputType="text"
        android:autofillHints="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/chipGroupFilter" />
  <View
      android:id="@+id/background_header"
      android:layout_width="0dp"
      android:layout_height="50dp"
      android:background="@drawable/bg_header_wave"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toTopOf="parent"/>

  <androidx.gridlayout.widget.GridLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="44dp"
      android:padding="16dp"
      app:columnCount="3"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/etCustom"
      app:useDefaultMargins="true">

    <com.google.android.material.button.MaterialButton
        android:text="Menu 1"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"
        />

    <com.google.android.material.button.MaterialButton
        android:text="Menu 2"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"/>

    <com.google.android.material.button.MaterialButton
        android:text="Menu 3"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"/>

    <com.google.android.material.button.MaterialButton
        android:text="Menu 4"
        app:layout_column="0"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:layout_row="1"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"/>

    <com.google.android.material.button.MaterialButton
        android:text="Menu 5"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"/>

    <com.google.android.material.button.MaterialButton
        android:text="Menu 6"
        app:layout_columnWeight="1"
        app:layout_gravity="fill_horizontal"
        app:icon="@drawable/ic_home"
        app:iconGravity="top"
        app:iconSize="40sp"/>
  </androidx.gridlayout.widget.GridLayout>


</androidx.constraintlayout.widget.ConstraintLayout>